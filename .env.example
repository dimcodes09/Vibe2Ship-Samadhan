# Samadhan - Civic Engagement Platform Environment Configuration
# Copy this file to .env and fill in the values before running the application.

# --- FRONTEND ENVIRONMENT CONFIGURATION ---
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key-here

# --- BACKEND / EDGE FUNCTIONS ENVIRONMENT CONFIGURATION ---
# The following keys must be set in your Supabase project settings or via CLI:
# Command: supabase secrets set ROBOFLOW_API_KEY=xxx GEMINI_API_KEY=xxx IP_SALT=xxx

# Roboflow API key for AI-based pothole and garbage detection
ROBOFLOW_API_KEY=your-roboflow-api-key-here

# Google Gemini API key for Gemini-2.5-flash civic assistant chat
GEMINI_API_KEY=your-gemini-api-key-here

# Private salt for privacy-first SHA-256 IP rate limit hashing
IP_SALT=change_this_to_a_long_random_string_in_production
